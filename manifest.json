{
    "manifest_version": 3,
    "name": "InstaAudio — Instagram Voice Message Downloader",
    "version": "3.0.0",
    "description": "Download & play Instagram DM voice messages instantly. Auto-captures audio clips — listen or save with one click!",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": [
        "webRequest",
        "downloads",
        "activeTab",
        "tabs"
    ],
    "host_permissions": [
        "*://*.fbcdn.net/*",
        "*://*.cdninstagram.com/*",
        "*://*.fbsbx.com/*",
        "*://*.facebook.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.instagram.com/direct/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}